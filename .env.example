# Environment variables for immich-dynamic-albums
# Copy this to .env and fill in the values.

# ---- Required ----

# A long random string used to sign Flask sessions.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Full URL of your Immich server (reachable from inside Docker).
# On Unraid, use the container name on the shared backend network:
IMMICH_URL=http://immich_server:2283

# Admin API key from Immich → Account Settings → API Keys.
# This key is used for all album management and user lookups.
# Users log in with their own Immich email + password; they never see this key.
IMMICH_API_KEY=your-admin-api-key-here

# ---- Authentication mode ----
# immich  → email + password login (default; requires local Immich passwords)
# oidc    → SSO/OIDC only (use when Immich itself uses OIDC)
# both    → show both options on the login page
AUTH_METHOD=immich

# ---- OIDC settings (required only when AUTH_METHOD is 'oidc' or 'both') ----
# Point to the same OIDC provider your Immich instance uses.
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ---- Database ----
# Password for the dedicated Postgres database (not the Immich DB).
DB_PASSWORD=change-me-db-password

# Host path for the Postgres data volume.
# On Unraid: /mnt/user/appdata/immich-dynamic-albums/db
DB_DATA_LOCATION=./pgdata

# ---- Web server ----
# Port exposed on the host.
WEB_PORT=5000

# ---- Sync scheduler ----
SYNC_ENABLED=true
GLOBAL_SYNC_INTERVAL=60

# ---- Logging ----
LOGS_LOCATION=/mnt/user/appdata/immich-dynamic-albums/logs
